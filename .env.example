HOST=127.0.0.1
PORT=8080
DRIVER=~fastapi
LOG_LEVEL=INFO

# NapCatQQ 的 OneBot token（如果你在 NapCat 中配置了 token，这里要保持一致）
ONEBOT_ACCESS_TOKEN=
# NapCat 容器镜像（按你实际使用的镜像填写）
NAPCAT_IMAGE=
# NapCat WebUI 映射到宿主机端口
NAPCAT_WEBUI_PORT=6099

# DeepSeek API 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30
QQ_MAX_REPLY_CHARS=4000
QQ_SPLIT_LONG_REPLY=true
DEEPSEEK_SYSTEM_PROMPT=你是一个在QQ里聊天的朋友，说话自然、口语化、有温度。优先短句，避免官腔和说教，不要自称AI或提模型。
DEEPSEEK_TEMPERATURE=0.9
DEEPSEEK_TOP_P=0.92
DEEPSEEK_MAX_TOKENS=350
STYLE_FEWSHOT_ENABLED=true
# JSON数组，可选。示例: [{"user":"今天好累","assistant":"辛苦啦，先喝口水歇两分钟？"}]
STYLE_FEWSHOT_JSON=
CONTEXT_ENABLED=true
CONTEXT_MAX_TURNS=6
# 上下文归属范围: auto(群聊按群、私聊按用户) / group / user
CONTEXT_SCOPE=auto
# 【已弃用】用户标记现在自动应用于群聊消息，用于帮助模型识别不同发言者
# CONTEXT_GROUP_SPEAKER_TAG=true
# 重启后是否从 chat_raw.jsonl 恢复最近上下文
CONTEXT_RESTORE_ON_START=true
CONTEXT_RESTORE_MAX_MESSAGES=40
# 会话快照持久化（重启优先从快照恢复）
CONTEXT_PERSIST_ENABLED=true
CONTEXT_PERSIST_FILE=context_sessions.json

# 本地联调测试接口（不依赖 NapCat）
TEST_API_ENABLED=true
# 建议在服务器设置；调用时通过请求头 X-Test-Token 传入
TEST_API_TOKEN=

# 对话数据集存储配置（用于后续微调）
SAVE_DATASET_ENABLED=true
DATASET_DIR=./data
RAW_LOG_FILE=chat_raw.jsonl
FINETUNE_FILE=chat_finetune.jsonl
